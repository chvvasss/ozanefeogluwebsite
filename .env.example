# =============================================================================
# Application
# =============================================================================
APP_NAME="Ozan Efeoğlu"
APP_ENV=local                   # local | staging | production
APP_KEY=                        # `php artisan key:generate`
APP_DEBUG=true                  # PRODUCTION'DA ZORUNLU FALSE
APP_URL=http://localhost:8000
APP_TIMEZONE=Europe/Istanbul

# Locales (ADR-011)
APP_LOCALE=tr
APP_FALLBACK_LOCALE=tr
APP_FAKER_LOCALE=tr_TR
AVAILABLE_LOCALES=tr,en
APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12
BROADCAST_CONNECTION=log

# =============================================================================
# Database (ADR-002)
# =============================================================================
DB_CONNECTION=mysql             # mysql | sqlite | pgsql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ozanefeoglu
DB_USERNAME=root
DB_PASSWORD=

# =============================================================================
# Cache & Session & Queue (ADR-009)
# =============================================================================
CACHE_STORE=redis               # redis | file (shared hosting fallback)
SESSION_DRIVER=redis            # redis | file | database
SESSION_LIFETIME=480            # admin idle minutes (8h absolute via app code)
SESSION_ENCRYPT=false
SESSION_SECURE_COOKIE=true      # production'da true zorunlu
SESSION_SAME_SITE=strict
SESSION_PATH=/
SESSION_DOMAIN=null

LOG_DEPRECATIONS_CHANNEL=null
QUEUE_CONNECTION=redis          # redis | database | sync (dev)

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

MEMCACHED_HOST=127.0.0.1

# =============================================================================
# Mail (transactional + newsletter)
# =============================================================================
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="hello@ozanefeoglu.com"
MAIL_FROM_NAME="${APP_NAME}"

# =============================================================================
# Storage (ADR-007)
# =============================================================================
FILESYSTEM_DISK=local           # local | s3 (cloudflare r2, b2, minio)

# S3-compatible (R2 example)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=auto
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=true
AWS_ENDPOINT=                   # https://<account>.r2.cloudflarestorage.com
AWS_URL=                        # public CDN url for assets

# Image processing
IMAGE_DRIVER=imagick            # imagick | gd

# =============================================================================
# Search (ADR-008)
# =============================================================================
SEARCH_DRIVER=meilisearch       # meilisearch | mysql
MEILISEARCH_HOST=http://127.0.0.1:7700
MEILISEARCH_KEY=                # master key (production strict)

# =============================================================================
# Auth & 2FA (ADR-010)
# =============================================================================
HASH_DRIVER=argon2id
ARGON_MEMORY_COST=65536         # 64MB
ARGON_TIME_COST=4
ARGON_THREADS=2

REQUIRE_2FA_FOR_ADMIN=true
HIBP_ENABLED=true                # production'da true; dev'de devre dışı bırakılabilir
HIBP_API_BASE=https://api.pwnedpasswords.com
HIBP_TIMEOUT=3                  # seconds

# Login throttle (per minute, per IP+username)
AUTH_LOGIN_THROTTLE_ATTEMPTS=5
AUTH_LOGIN_LOCKOUT_MINUTES=15
AUTH_LOGIN_DAILY_LOCKOUT_THRESHOLD=10

# =============================================================================
# Site / theme (admin-overridable; here = boot defaults)
# =============================================================================
SITE_TITLE="${APP_NAME}"
SITE_TAGLINE="Builds quietly ambitious software."
SITE_THEME_PRESET=terracotta    # see docs/discovery/design-tokens.md

# =============================================================================
# Analytics (self-host)
# =============================================================================
ANALYTICS_PROVIDER=builtin      # builtin | plausible | umami | none
PLAUSIBLE_HOST=
PLAUSIBLE_DOMAIN=

# =============================================================================
# Newsletter
# =============================================================================
NEWSLETTER_DOUBLE_OPT_IN=true
NEWSLETTER_FROM=newsletter@ozanefeoglu.com

# =============================================================================
# Backup (Spatie)
# =============================================================================
BACKUP_ARCHIVE_PASSWORD=        # encryption password (zip aes); prod: REQUIRED
BACKUP_KEEP_LATEST=14
BACKUP_DESTINATION=local        # local | s3
BACKUP_NOTIFICATION_EMAIL=

# =============================================================================
# Logging & errors
# =============================================================================
LOG_CHANNEL=stack
LOG_STACK=daily,errorlog
LOG_LEVEL=info                  # debug only in dev
LOG_DAYS=14
GLITCHTIP_DSN=                  # optional, faz 7

# =============================================================================
# Maintenance
# =============================================================================
MAINTENANCE_BYPASS_IPS=         # comma-separated allowlist
MAINTENANCE_SECRET=             # bypass URL token

# =============================================================================
# CSP nonce / security headers
# =============================================================================
SECURITY_HSTS_MAX_AGE=63072000
SECURITY_CSP_REPORT_URI=        # optional report endpoint

# =============================================================================
# Site identity & contact (config/site.php)
# Bu değerler boş bırakılırsa view'lar ilgili bloğu HİÇ göstermez (ADR-016).
# Sahte veri / placeholder konmaz; gerçek kanal yayına alındığında doldurulur.
# =============================================================================
SITE_CONTACT_EMAIL=press@ozanefeoglu.com
SITE_SIGNAL_URL=                # signal.me link (örn. https://signal.me/#u/...)
SITE_PGP_FINGERPRINT=           # 4-grup hex parmak izi; boşsa PGP bloğu gizli
SITE_PGP_KEY_ID=
SITE_PGP_DOWNLOAD=              # .asc public key URL'si
SITE_TWITTER_URL=
SITE_INSTAGRAM_URL=
SITE_LINKEDIN_URL=
SITE_SHOW_VISUALS_NAV=false     # "Görüntü" nav, foto arşivi yayınlanınca true
SITE_CURRENT_CONTEXT=           # "Şu sıralar" tek-satır not (anasayfa rail). Boşsa rail gizli.
SITE_DEFAULT_PHOTO_CREDIT="Foto: Ozan Efeoğlu / AA"   # photo.default_credit fallback
SITE_AA_AFFILIATION_APPROVED=true                     # AA bağı footer/about gösterimi

# =============================================================================
# Initial admin (Database\Seeders\SuperAdminSeeder)
# `php artisan db:seed --class=SuperAdminSeeder` ile (yeniden) oluştur.
# =============================================================================
ADMIN_EMAIL=admin@ozanefeoglu.com
ADMIN_NAME="Yönetici"
ADMIN_PASSWORD=                  # BOŞ ASLA — production'da güçlü şifre koy

# =============================================================================
# Media library (spatie/laravel-medialibrary)
# AA orijinalleri 25-50 MB; default 10 MB yetmez.
# =============================================================================
MEDIA_DISK=public
MEDIA_MAX_FILE_SIZE=83886080     # 80 MB

# =============================================================================
# AA photo importer (php artisan aa:import-photos)
# =============================================================================
AA_PHOTO_SOURCE=                 # absolute path to .jpg directory

# =============================================================================
# Vite (frontend build)
# =============================================================================
VITE_APP_NAME="${APP_NAME}"
