# =============================================================================
# .env.production — ozanefeoglu.com PRODUCTION TEMPLATE
# -----------------------------------------------------------------------------
# Copy this to /var/www/ozanefeoglu.com/.env and fill in <PLACEHOLDER> values.
# After editing: chmod 600 .env && chown www-data:www-data .env
# =============================================================================

APP_NAME="Ozan Efeoğlu"
APP_ENV=production
APP_KEY=                          # `php artisan key:generate --force`
APP_DEBUG=false
APP_URL=https://ozanefeoglu.com
APP_TIMEZONE=Europe/Istanbul

APP_LOCALE=tr
APP_FALLBACK_LOCALE=tr
APP_FAKER_LOCALE=tr_TR
AVAILABLE_LOCALES=tr
APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12
BROADCAST_CONNECTION=log

# =============================================================================
# Database — MySQL 8 / PostgreSQL 16 (production: NOT sqlite)
# =============================================================================
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ozanefeoglu_prod
DB_USERNAME=ozan_app
DB_PASSWORD=<32-char-random>      # `openssl rand -base64 24`

# =============================================================================
# Cache + Session + Queue — Redis (sticks with Laravel scheduler / Spatie)
# =============================================================================
CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=480              # 8 hours absolute
SESSION_ENCRYPT=true              # AES payload (defense in depth)
SESSION_SECURE_COOKIE=true        # HTTPS-only cookies
SESSION_SAME_SITE=strict          # CSRF + cross-origin protection
SESSION_HTTP_ONLY=true            # block JS access (XSS mitigation)
SESSION_PATH=/
SESSION_DOMAIN=null

QUEUE_CONNECTION=redis
QUEUE_FAILED_DRIVER=database

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=<redis-password>   # `openssl rand -base64 24`; set in /etc/redis/redis.conf
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning                 # production: warning+; never debug

# =============================================================================
# Mail — SMTP provider (Mailgun, Postmark, Brevo, SendGrid)
# =============================================================================
MAIL_MAILER=smtp
MAIL_HOST=<smtp.mailgun.org or smtp.postmarkapp.com>
MAIL_PORT=587
MAIL_USERNAME=<smtp-user>
MAIL_PASSWORD=<smtp-pass>
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="hello@ozanefeoglu.com"
MAIL_FROM_NAME="${APP_NAME}"

# =============================================================================
# Initial super-admin (only used by SuperAdminSeeder on first deploy)
# Change immediately after first login + enable 2FA.
# =============================================================================
ADMIN_NAME="Ozan Efeoğlu"
ADMIN_EMAIL=<owner-email>
ADMIN_PASSWORD=<32-char-random>   # `openssl rand -base64 24`

# =============================================================================
# Login security
# =============================================================================
AUTH_LOGIN_THROTTLE_ATTEMPTS=5
AUTH_LOGIN_LOCKOUT_MINUTES=15
AUTH_LOGIN_DAILY_LOCKOUT_THRESHOLD=10
AUTH_LOGIN_ALERT_THRESHOLD=5

# =============================================================================
# HIBP password breach check (k-anonymity, no full hash leaves the server)
# =============================================================================
HIBP_ENABLED=true
HIBP_API_BASE=https://api.pwnedpasswords.com
HIBP_TIMEOUT=3

# =============================================================================
# Backup — daily DB to local + weekly full to S3
# =============================================================================
BACKUP_ARCHIVE_PASSWORD=<32-char-random>  # encrypts the zip; REQUIRED in prod
BACKUP_KEEP_LATEST=14
BACKUP_DESTINATION=s3                      # local | s3
BACKUP_INCLUDE_MEDIA=false                 # weekly full sets this to true
BACKUP_NOTIFICATION_EMAIL=<owner-email>

# Object storage — Cloudflare R2 / AWS S3 / Backblaze B2 / DigitalOcean Spaces
AWS_ACCESS_KEY_ID=<key>
AWS_SECRET_ACCESS_KEY=<secret>
AWS_DEFAULT_REGION=auto                    # R2 = auto, AWS S3 = eu-central-1
AWS_BUCKET=ozanefeoglu-backup
AWS_USE_PATH_STYLE_ENDPOINT=false
AWS_ENDPOINT=https://<account>.r2.cloudflarestorage.com   # R2 only

# =============================================================================
# Media — photos
# =============================================================================
MEDIA_DISK=public                  # 'public' (local) | 's3' (offload to bucket)
MEDIA_MAX_FILE_SIZE=83886080       # 80 MB
MEDIA_PHOTO_QUALITY=85
MEDIA_PHOTO_PROGRESSIVE=true

# =============================================================================
# Security headers
# =============================================================================
SECURITY_CSP_ENABLED=true
SECURITY_HSTS_ENABLED=true
SECURITY_HSTS_MAX_AGE=63072000
SECURITY_CSP_REPORT_URI=                   # optional: CSP violation collector

# =============================================================================
# reCAPTCHA Enterprise (contact form bot defense — KVKK-friendly)
# =============================================================================
RECAPTCHA_ENABLED=true
RECAPTCHA_SITE_KEY=<google-recaptcha-key>
RECAPTCHA_SECRET=<google-recaptcha-secret>
RECAPTCHA_THRESHOLD=0.5

# =============================================================================
# Error monitoring (optional, recommended)
# =============================================================================
SENTRY_LARAVEL_DSN=<dsn>
SENTRY_TRACES_SAMPLE_RATE=0.1

# =============================================================================
# Feature flags (mirror site_settings table — these are env overrides)
# =============================================================================
FEATURE_FEED_ENABLED=false                 # RSS feed
FEATURE_SEARCH_ENABLED=false               # Phase 3 search
FEATURE_COMMENTS_ENABLED=false             # never; comments OFF by design

# =============================================================================
# Trust upstream proxies — for Cloudflare, Caddy, Nginx
# (handled in bootstrap/app.php; documented here for clarity)
# =============================================================================
TRUSTED_PROXIES=*
